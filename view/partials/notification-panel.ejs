<!-- Notification Panel Partial -->
<!-- Usage: <%- include('partials/notification-panel') %> -->

<div class="notification-panel" id="notification-panel">
    <!-- Notification Dropdown -->
    <div class="nav-item dropdown">
        <button class="nav-link btn btn-link position-relative" type="button"
                id="notificationDropdown" data-bs-toggle="dropdown"
                aria-expanded="false" title="Notifikasi">
            <i class="fas fa-bell fa-lg"></i>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger notification-badge d-none">
                0
            </span>
        </button>

        <!-- Notification Dropdown Menu -->
        <div class="dropdown-menu dropdown-menu-end notification-dropdown-menu" aria-labelledby="notificationDropdown"
             style="max-height: 500px; min-width: 350px; overflow-y: auto;">
            <!-- Header -->
            <div class="dropdown-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Notifikasi</h6>
                <button type="button" class="btn btn-sm btn-ghost" id="clear-all-notifications" title="Tandai semua sebagai baca">
                    <i class="fas fa-check-double"></i>
                </button>
            </div>

            <hr class="dropdown-divider m-0">

            <!-- Notification Items Container -->
            <div id="notifications-container" class="notification-items">
                <!-- Notifications will be loaded here -->
                <div class="dropdown-item text-muted text-center py-4">
                    <i class="fas fa-inbox"></i>
                    <p class="mb-0">Tidak ada notifikasi</p>
                </div>
            </div>

            <!-- Footer -->
            <hr class="dropdown-divider m-0">
            <div class="dropdown-footer text-center py-2">
                <a href="/notifications" class="btn btn-sm btn-link">Lihat Semua Notifikasi</a>
            </div>
        </div>
    </div>
</div>

<style>
    .notification-dropdown-menu {
        border: 1px solid #e9ecef;
        border-radius: 0.5rem;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    }

    .notification-dropdown-menu .dropdown-header {
        background: #f8f9fa;
        padding: 1rem;
    }

    .notification-dropdown-menu .dropdown-header h6 {
        font-weight: 600;
    }

    .notification-items {
        max-height: 400px;
        overflow-y: auto;
    }

    .notification-item {
        background: white;
        transition: background-color 0.2s;
        cursor: pointer;
    }

    .notification-item:hover {
        background: #f8f9fa;
    }

    .notification-item.unread {
        background: #e7f3ff;
        border-left: 3px solid #007bff;
    }

    .notification-item h6 {
        color: #333;
        font-weight: 600;
        font-size: 0.95rem;
    }

    .notification-item .text-muted {
        font-size: 0.85rem;
    }

    .notification-item .badge {
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.35rem 0.5rem;
    }

    .badge-info {
        background-color: #17a2b8;
    }

    .badge-success {
        background-color: #28a745;
    }

    .badge-danger {
        background-color: #dc3545;
    }

    .badge-primary {
        background-color: #007bff;
    }

    .badge-warning {
        background-color: #ffc107;
        color: #333;
    }

    .badge-secondary {
        background-color: #6c757d;
    }

    .badge-light {
        background-color: #f8f9fa;
        color: #333;
    }

    .notification-close {
        padding: 0;
        width: 24px;
        height: 24px;
        opacity: 0.5;
        transition: opacity 0.2s;
    }

    .notification-close:hover {
        opacity: 1;
    }

    .dropdown-footer {
        background: #f8f9fa;
    }

    .dropdown-footer a {
        text-decoration: none;
        color: #007bff;
        font-weight: 500;
    }

    .dropdown-footer a:hover {
        color: #0056b3;
        text-decoration: underline;
    }

    .btn-ghost {
        background: transparent;
        border: none;
        color: #6c757d;
        padding: 0.25rem 0.5rem;
    }

    .btn-ghost:hover {
        color: #007bff;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .notification-dropdown-menu {
            min-width: 280px !important;
        }
    }
</style>

<script src="/js/notification-polling.js"></script>

<script>
    // Initialize notification poller when page loads
    document.addEventListener('DOMContentLoaded', () => {
        // Create notification poller instance
        window.notificationPoller = new NotificationPoller({
            badgeElement: '.notification-badge',
            notificationPanel: '#notifications-container',
            pollInterval: 5000,
            onNewNotification: handleNewNotifications
        });

        // Start polling
        window.notificationPoller.start();

        // Setup event listeners
        setupNotificationListeners();

        // Initial load
        loadNotifications();
    });

    /**
     * Load initial notifications
     */
    async function loadNotifications() {
        try {
            const response = await fetch('/api/notifications?page=1&limit=10', {
                headers: {
                    'Authorization': `Bearer ${getAuthToken()}`
                }
            });

            if (!response.ok) throw new Error('Failed to load notifications');

            const data = await response.json();
            displayNotifications(data.data.notifications);

            // Update badge
            await window.notificationPoller.updateBadgeCount();
        } catch (error) {
            console.error('Error loading notifications:', error);
        }
    }

    /**
     * Display notifications in the panel
     */
    function displayNotifications(notifications) {
        const container = document.getElementById('notifications-container');

        if (notifications.length === 0) {
            container.innerHTML = `
                <div class="dropdown-item text-muted text-center py-4">
                    <i class="fas fa-inbox"></i>
                    <p class="mb-0">Tidak ada notifikasi</p>
                </div>
            `;
            return;
        }

        let html = '';
        notifications.forEach(notif => {
            const badgeClass = getTypeBadgeClass(notif.type_name);
            const timeString = getRelativeTime(notif.created_at);
            const unreadClass = notif.is_read ? '' : 'unread';

            html += `
                <div class="notification-item p-3 ${unreadClass}"
                     data-notification-id="${notif.notification_id}"
                     data-reference-id="${notif.reference_id}"
                     data-reference-type="${notif.reference_type}">
                    <div class="d-flex align-items-start gap-2">
                        <span class="badge ${badgeClass} mt-1" style="font-size: 0.7rem;" data-type-name="${notif.type_name}">${notif.type_name}</span>
                        <div class="flex-grow-1 flex-shrink-1">
                            <h6 class="mb-1">${escapeHtml(notif.title)}</h6>
                            <p class="mb-1 text-muted small">${escapeHtml(notif.message)}</p>
                            <small class="text-secondary">${timeString}</small>
                        </div>
                        <button class="btn btn-sm btn-close notification-close"
                                data-notification-id="${notif.notification_id}"
                                type="button"
                                aria-label="Close"></button>
                    </div>
                </div>
            `;
        });

        container.innerHTML = html;
    }

    /**
     * Setup notification event listeners
     */
    function setupNotificationListeners() {
        // Handle notification click (mark as read + redirect)
        document.addEventListener('click', async (e) => {
            const notifItem = e.target.closest('.notification-item');
            if (notifItem && !e.target.closest('.notification-close')) {
                const notifId = notifItem.dataset.notificationId;
                const refId = notifItem.dataset.referenceId;
                const refType = notifItem.dataset.referenceType;
                const typeName = notifItem.querySelector('[data-type-name]')?.dataset.typeName;

                // Mark as read
                await window.notificationPoller.markAsRead(notifId);

                // Redirect based on notification type (smart redirect)
                redirectToReference(refType, refId, typeName);
            }

            // Handle close button
            const closeBtn = e.target.closest('.notification-close');
            if (closeBtn) {
                e.stopPropagation();
                const notifId = closeBtn.dataset.notificationId;
                await window.notificationPoller.deleteNotification(notifId);
            }
        });

        // Handle mark all as read
        document.getElementById('clear-all-notifications')?.addEventListener('click', async () => {
            try {
                const response = await fetch('/api/notifications/mark-all/read', {
                    method: 'PATCH',
                    headers: {
                        'Authorization': `Bearer ${getAuthToken()}`
                    }
                });

                if (response.ok) {
                    // Refresh notifications
                    await loadNotifications();
                    // Update badge
                    await window.notificationPoller.updateBadgeCount();
                }
            } catch (error) {
                console.error('Error marking all as read:', error);
            }
        });
    }

    /**
     * Handle new notifications from polling
     */
    function handleNewNotifications(notifications) {
        console.log(`Received ${notifications.length} new notification(s)`);
        loadNotifications();
    }

    /**
     * Redirect to relevant page based on notification type (SMART REDIRECT)
     * - BARTER_REQUEST → Chat/Transaction detail page
     * - NEW_MESSAGE → Chat page directly
     * - BARTER_ACCEPTED/REJECTED → Transaction detail
     * - ITEM_MATCHED → Item detail
     * - REVIEW_RECEIVED → User profile
     */
    function redirectToReference(refType, refId, typeName) {
        if (!refType || !refId) return;

        // Smart redirect based on notification type
        switch (typeName) {
            case 'BARTER_REQUEST':
                // Barter request → go to transaction detail page
                window.location.href = `/barter/${refId}/page`;
                break;
            case 'BARTER_ACCEPTED':
            case 'BARTER_REJECTED':
                // Status changed → go to transaction detail page
                window.location.href = `/barter/${refId}/page`;
                break;
            case 'NEW_MESSAGE':
                // New message → go directly to transaction page
                window.location.href = `/barter/${refId}/page`;
                break;
            case 'ITEM_MATCHED':
                // Item matched → go to item detail
                if (refType === 'ITEM') {
                    window.location.href = `/items/${refId}`;
                } else if (refType === 'TRANSACTION') {
                    window.location.href = `/barter/${refId}`;
                }
                break;
            case 'REVIEW_RECEIVED':
                // Review → go to user profile
                if (refType === 'USER') {
                    window.location.href = `/users/${refId}`;
                }
                break;
            default:
                // Default fallback based on reference type
                switch (refType) {
                    case 'TRANSACTION':
                        window.location.href = `/barter/${refId}`;
                        break;
                    case 'ITEM':
                        window.location.href = `/items/${refId}`;
                        break;
                    case 'USER':
                        window.location.href = `/users/${refId}`;
                        break;
                }
        }
    }

    /**
     * Get badge class by type
     */
    function getTypeBadgeClass(typeName) {
        const badgeMap = {
            'BARTER_REQUEST': 'badge-info',
            'BARTER_ACCEPTED': 'badge-success',
            'BARTER_REJECTED': 'badge-danger',
            'NEW_MESSAGE': 'badge-primary',
            'REVIEW_RECEIVED': 'badge-warning',
            'ITEM_MATCHED': 'badge-secondary',
            'SYSTEM': 'badge-light'
        };
        return badgeMap[typeName] || 'badge-secondary';
    }

    /**
     * Get relative time
     */
    function getRelativeTime(dateString) {
        const date = new Date(dateString);
        const now = new Date();
        const seconds = Math.floor((now - date) / 1000);

        if (seconds < 60) return 'barusan';
        if (seconds < 3600) return `${Math.floor(seconds / 60)}m yang lalu`;
        if (seconds < 86400) return `${Math.floor(seconds / 3600)}j yang lalu`;
        if (seconds < 604800) return `${Math.floor(seconds / 86400)}h yang lalu`;

        return date.toLocaleDateString('id-ID');
    }

    /**
     * Escape HTML
     */
    function escapeHtml(text) {
        const map = {
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#039;'
        };
        return text.replace(/[&<>"']/g, m => map[m]);
    }

    /**
     * Get auth token
     */
    function getAuthToken() {
        return localStorage.getItem('authToken') ||
               sessionStorage.getItem('authToken') ||
               document.cookie.split(';').find(c => c.includes('token'))?.split('=')[1] ||
               '';
    }
</script>
