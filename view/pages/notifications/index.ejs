<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notifikasi - Barterin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background-color: #f3f4f6;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }

        .page-header {
            background: linear-gradient(135deg, #4f46e5 0%, #4338ca 100%);
            color: white;
            padding: 2rem 0;
            margin-bottom: 2rem;
        }

        .page-header h1 {
            font-weight: 600;
            margin: 0;
        }

        .filter-tabs {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

        .filter-tabs .btn {
            border-radius: 2rem;
            font-weight: 500;
            padding: 0.5rem 1.25rem;
            white-space: nowrap;
        }

        .filter-tabs .btn-outline-secondary {
            color: #6c757d;
            border-color: #dee2e6;
        }

        .filter-tabs .btn-primary {
            background: #4f46e5;
        }

        .notification-card {
            background: white;
            border: 1px solid #e9ecef;
            border-radius: 0.5rem;
            padding: 1.5rem;
            margin-bottom: 1rem;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .notification-card:hover {
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            transform: translateY(-2px);
        }

        .notification-card.unread {
            background: #eef2ff;
            border-left: 4px solid #4f46e5;
        }

        .notification-card.read {
            opacity: 0.85;
        }

        .notification-header {
            display: flex;
            justify-content: space-between;
            align-items: start;
            margin-bottom: 0.75rem;
        }

        .notification-title {
            flex: 1;
        }

        .notification-title h5 {
            margin: 0;
            font-weight: 600;
            color: #333;
            font-size: 1rem;
        }

        .notification-badge {
            font-size: 0.7rem;
            font-weight: 600;
            padding: 0.35rem 0.75rem;
            margin-left: 0.5rem;
        }

        .badge-info {
            background-color: #17a2b8;
        }

        .badge-success {
            background-color: #28a745;
        }

        .badge-danger {
            background-color: #dc3545;
        }

        .badge-primary {
            background-color: #4f46e5;
        }

        .badge-warning {
            background-color: #ffc107;
            color: #333;
        }

        .badge-secondary {
            background-color: #6c757d;
        }

        .badge-light {
            background-color: #f8f9fa;
            color: #333;
        }

        .notification-message {
            color: #6c757d;
            font-size: 0.95rem;
            margin-bottom: 0.75rem;
            line-height: 1.5;
        }

        .notification-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid #e9ecef;
        }

        .notification-time {
            font-size: 0.85rem;
            color: #adb5bd;
        }

        .notification-actions {
            display: flex;
            gap: 0.5rem;
        }

        .notification-actions .btn {
            padding: 0.35rem 0.75rem;
            font-size: 0.85rem;
        }

        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
            color: #6c757d;
        }

        .empty-state i {
            font-size: 3rem;
            opacity: 0.5;
            margin-bottom: 1rem;
        }

        .empty-state h5 {
            color: #333;
            margin-bottom: 0.5rem;
        }

        .pagination {
            justify-content: center;
            margin-top: 2rem;
        }

        .pagination .page-link {
            color: #4f46e5;
            border-color: #dee2e6;
        }

        .pagination .page-link:hover {
            color: #0056b3;
            background-color: #f8f9fa;
        }

        .pagination .page-link.active {
            background-color: #4f46e5;
            border-color: #4f46e5;
        }

        .toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .toolbar-stats {
            display: flex;
            gap: 2rem;
            font-size: 0.95rem;
            color: #6c757d;
        }

        .toolbar-actions {
            display: flex;
            gap: 0.5rem;
        }

        .toolbar-actions .btn {
            padding: 0.5rem 1rem;
            font-size: 0.9rem;
        }

        .loading {
            text-align: center;
            padding: 2rem;
        }

        .loading-spinner {
            display: inline-block;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .page-header {
                padding: 1.5rem 0;
                margin-bottom: 1.5rem;
            }

            .page-header h1 {
                font-size: 1.5rem;
            }

            .notification-card {
                padding: 1rem;
            }

            .notification-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .notification-badge {
                margin-left: 0;
                margin-top: 0.5rem;
            }

            .toolbar {
                flex-direction: column;
                align-items: flex-start;
            }

            .toolbar-stats {
                flex-direction: column;
                gap: 0.5rem;
            }

            .toolbar-actions {
                width: 100%;
            }

            .toolbar-actions .btn {
                flex: 1;
            }

            .filter-tabs {
                width: 100%;
            }

            .filter-tabs .btn {
                flex: 1;
            }
        }
    </style>
</head>
<body>
<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-bell"></i> Notifikasi</h1>
        <p class="mb-0 mt-2 opacity-75">Kelola dan lihat semua notifikasi Anda</p>
    </div>
</div>

<div class="container">
    <!-- Toolbar -->
    <div class="toolbar">
        <div class="toolbar-stats">
            <div>
                <strong>Total:</strong> <span id="total-count">0</span>
            </div>
            <div>
                <strong>Belum Dibaca:</strong> <span id="unread-count">0</span>
            </div>
        </div>
        <div class="toolbar-actions">
            <button class="btn btn-outline-primary btn-sm" id="mark-all-read-btn">
                <i class="fas fa-check-double"></i> Tandai Semua Baca
            </button>
            <button class="btn btn-outline-danger btn-sm" id="delete-old-btn">
                <i class="fas fa-trash"></i> Hapus Lama
            </button>
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="filter-tabs" id="filter-tabs">
        <button class="btn btn-primary" data-filter="all">
            <i class="fas fa-inbox"></i> Semua
        </button>
        <button class="btn btn-outline-secondary" data-filter="BARTER_REQUEST">
            <i class="fas fa-exchange-alt"></i> Permintaan Barter
        </button>
        <button class="btn btn-outline-secondary" data-filter="NEW_MESSAGE">
            <i class="fas fa-comment"></i> Pesan Baru
        </button>
        <button class="btn btn-outline-secondary" data-filter="BARTER_ACCEPTED">
            <i class="fas fa-check-circle"></i> Diterima
        </button>
        <button class="btn btn-outline-secondary" data-filter="BARTER_REJECTED">
            <i class="fas fa-times-circle"></i> Ditolak
        </button>
        <button class="btn btn-outline-secondary" data-filter="unread">
            <i class="fas fa-circle"></i> Belum Dibaca
        </button>
    </div>

    <!-- Notifications Container -->
    <div id="notifications-container">
        <div class="loading">
            <div class="loading-spinner">
                <i class="fas fa-circle-notch fa-spin fa-2x"></i>
            </div>
            <p class="mt-2">Memuat notifikasi...</p>
        </div>
    </div>

    <!-- Pagination -->
    <nav id="pagination-nav" class="d-none" aria-label="Page navigation">
        <ul class="pagination" id="pagination"></ul>
    </nav>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // State
    let currentFilter = 'all';
    let currentPage = 1;
    let totalNotifications = 0;

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
        setupEventListeners();
        loadNotifications();
        updateStats();
    });

    /**
     * Setup event listeners
     */
    function setupEventListeners() {
        // Filter tabs
        document.querySelectorAll('#filter-tabs .btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('#filter-tabs .btn').forEach(b =>
                    b.classList.remove('btn-primary')
                );
                document.querySelectorAll('#filter-tabs .btn').forEach(b =>
                    b.classList.add('btn-outline-secondary')
                );
                btn.classList.remove('btn-outline-secondary');
                btn.classList.add('btn-primary');

                currentFilter = btn.dataset.filter;
                currentPage = 1;
                loadNotifications();
            });
        });

        // Mark all read
        document.getElementById('mark-all-read-btn').addEventListener('click', async () => {
            if (!confirm('Tandai semua notifikasi sebagai baca?')) {
                return;
            }

            try {
                const response = await fetch('/api/notifications/mark-all/read', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${getAuthToken()}`
                    }
                });

                const data = await response.json().catch(() => null);

                if (!response.ok || !data || data.success === false) {
                    const message = (data && data.message) || 'Gagal menandai semua notifikasi sebagai baca';
                    showError(message);
                    return;
                }

                await loadNotifications();
                await updateStats();
                showSuccess('Semua notifikasi sudah ditandai sebagai baca');
            } catch (error) {
                console.error('Error marking all as read:', error);
                showError('Gagal menandai semua notifikasi sebagai baca');
            }
        });

        // Delete old notifications
        document.getElementById('delete-old-btn').addEventListener('click', async () => {
            if (confirm('Hapus notifikasi yang lebih dari 30 hari?')) {
                try {
                    const response = await fetch('/api/notifications/cleanup', {
                        method: 'POST',
                        headers: {
                            'Authorization': `Bearer ${getAuthToken()}`
                        }
                    });

                    if (response.ok) {
                        const data = await response.json();
                        await loadNotifications();
                        await updateStats();
                        showSuccess(`${data.data.deleted_count} notifikasi lama berhasil dihapus`);
                    }
                } catch (error) {
                    console.error('Error:', error);
                    showError('Gagal menghapus notifikasi lama');
                }
            }
        });
    }

    /**
     * Load notifications
     */
    async function loadNotifications(page = 1) {
        currentPage = page;
        const container = document.getElementById('notifications-container');

        try {
            let url = `/api/notifications?page=${page}&limit=20`;
            if (currentFilter !== 'all' && currentFilter !== 'unread') {
                url = `/api/notifications/type/${currentFilter}?page=${page}&limit=20`;
            }

            const response = await fetch(url, {
                headers: {
                    'Authorization': `Bearer ${getAuthToken()}`
                }
            });

            if (!response.ok) throw new Error('Failed to load notifications');

            const data = await response.json();

            if (!data.data.notifications || data.data.notifications.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-inbox"></i>
                        <h5>Tidak ada notifikasi</h5>
                        <p>Anda tidak memiliki notifikasi untuk filter ini</p>
                    </div>
                `;
                document.getElementById('pagination-nav').classList.add('d-none');
                return;
            }

            // Filter unread if needed
            let notifications = data.data.notifications;
            if (currentFilter === 'unread') {
                notifications = notifications.filter(n => !n.is_read);
            }

            // Display notifications
            displayNotifications(notifications);

            // Update pagination
            if (data.data.pagination) {
                updatePagination(data.data.pagination);
            }

            totalNotifications = data.data.pagination?.total_items || 0;
        } catch (error) {
            console.error('Error loading notifications:', error);
            container.innerHTML = `
                <div class="alert alert-danger" role="alert">
                    <i class="fas fa-exclamation-circle"></i> Gagal memuat notifikasi
                </div>
            `;
        }
    }

    /**
     * Display notifications
     */
    function displayNotifications(notifications) {
        const container = document.getElementById('notifications-container');
        let html = '';

        notifications.forEach(notif => {
            const badgeClass = getTypeBadgeClass(notif.type_name);
            const timeString = getRelativeTime(notif.created_at);
            const readClass = notif.is_read ? 'read' : 'unread';

            html += `
                <div class="notification-card ${readClass}" data-notification-id="${notif.notification_id}">
                    <div class="notification-header">
                        <div class="notification-title">
                            <h5>
                                ${escapeHtml(notif.title)}
                                <span class="badge ${badgeClass} notification-badge">${notif.type_name}</span>
                            </h5>
                        </div>
                        <div>
                            ${!notif.is_read ? '<span class="badge bg-primary">Baru</span>' : ''}
                        </div>
                    </div>
                    <p class="notification-message">${escapeHtml(notif.message)}</p>
                    <div class="notification-footer">
                        <div class="notification-time">
                            <i class="fas fa-clock"></i> ${timeString}
                        </div>
                        <div class="notification-actions">
                            ${!notif.is_read ? `
                                <button class="btn btn-sm btn-outline-primary mark-read-btn"
                                        data-notification-id="${notif.notification_id}">
                                    <i class="fas fa-check"></i> Tandai Baca
                                </button>
                            ` : ''}
                            <button class="btn btn-sm btn-outline-danger delete-btn"
                                    data-notification-id="${notif.notification_id}">
                                <i class="fas fa-trash"></i> Hapus
                            </button>
                        </div>
                    </div>
                </div>
            `;
        });

        container.innerHTML = html;

        // Setup action listeners
        document.querySelectorAll('.mark-read-btn').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const notifId = btn.dataset.notificationId;
                try {
                    const response = await fetch(`/api/notifications/${notifId}/read`, {
                        method: 'PATCH',
                        headers: {
                            'Authorization': `Bearer ${getAuthToken()}`
                        }
                    });

                    if (response.ok) {
                        await loadNotifications(currentPage);
                        await updateStats();
                    }
                } catch (error) {
                    console.error('Error:', error);
                    showError('Gagal menandai notifikasi');
                }
            });
        });

        document.querySelectorAll('.delete-btn').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const notifId = btn.dataset.notificationId;
                if (confirm('Hapus notifikasi ini?')) {
                    try {
                        const response = await fetch(`/api/notifications/${notifId}`, {
                            method: 'DELETE',
                            headers: {
                                'Authorization': `Bearer ${getAuthToken()}`
                            }
                        });

                        if (response.ok) {
                            await loadNotifications(currentPage);
                            await updateStats();
                        }
                    } catch (error) {
                        console.error('Error:', error);
                        showError('Gagal menghapus notifikasi');
                    }
                }
            });
        });
    }

    /**
     * Update pagination
     */
    function updatePagination(pagination) {
        const nav = document.getElementById('pagination-nav');
        const paginationEl = document.getElementById('pagination');

        if (pagination.total_pages <= 1) {
            nav.classList.add('d-none');
            return;
        }

        nav.classList.remove('d-none');
        let html = '';

        // Previous
        if (pagination.has_prev) {
            html += `<li class="page-item"><a class="page-link" href="#" data-page="${pagination.current_page - 1}">Sebelumnya</a></li>`;
        } else {
            html += `<li class="page-item disabled"><span class="page-link">Sebelumnya</span></li>`;
        }

        // Page numbers
        for (let i = 1; i <= pagination.total_pages; i++) {
            if (i === pagination.current_page) {
                html += `<li class="page-item active"><span class="page-link">${i}</span></li>`;
            } else {
                html += `<li class="page-item"><a class="page-link" href="#" data-page="${i}">${i}</a></li>`;
            }
        }

        // Next
        if (pagination.has_next) {
            html += `<li class="page-item"><a class="page-link" href="#" data-page="${pagination.current_page + 1}">Selanjutnya</a></li>`;
        } else {
            html += `<li class="page-item disabled"><span class="page-link">Selanjutnya</span></li>`;
        }

        paginationEl.innerHTML = html;

        // Setup click handlers
        paginationEl.querySelectorAll('a.page-link').forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                loadNotifications(parseInt(link.dataset.page));
                window.scrollTo(0, 0);
            });
        });
    }

    /**
     * Update statistics
     */
    async function updateStats() {
        try {
            const response = await fetch('/api/notifications/unread/count', {
                headers: {
                    'Authorization': `Bearer ${getAuthToken()}`
                }
            });

            if (response.ok) {
                const data = await response.json();
                document.getElementById('unread-count').textContent = data.data.unread_count;
            }
        } catch (error) {
            console.error('Error updating stats:', error);
        }
    }

    /**
     * Get badge class
     */
    function getTypeBadgeClass(typeName) {
        const badgeMap = {
            'BARTER_REQUEST': 'badge-info',
            'BARTER_ACCEPTED': 'badge-success',
            'BARTER_REJECTED': 'badge-danger',
            'NEW_MESSAGE': 'badge-primary',
            'REVIEW_RECEIVED': 'badge-warning',
            'ITEM_MATCHED': 'badge-secondary',
            'SYSTEM': 'badge-light'
        };
        return badgeMap[typeName] || 'badge-secondary';
    }

    /**
     * Get relative time
     */
    function getRelativeTime(dateString) {
        const date = new Date(dateString);
        const now = new Date();
        const seconds = Math.floor((now - date) / 1000);

        if (seconds < 60) return 'barusan';
        if (seconds < 3600) return `${Math.floor(seconds / 60)}m yang lalu`;
        if (seconds < 86400) return `${Math.floor(seconds / 3600)}j yang lalu`;
        if (seconds < 604800) return `${Math.floor(seconds / 86400)}h yang lalu`;

        return date.toLocaleDateString('id-ID');
    }

    /**
     * Escape HTML
     */
    function escapeHtml(text) {
        const map = {
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#039;'
        };
        return text.replace(/[&<>"']/g, m => map[m]);
    }

    /**
     * Get auth token
     */
    function getAuthToken() {
        return localStorage.getItem('authToken') ||
               sessionStorage.getItem('authToken') ||
               document.cookie.split(';').find(c => c.includes('token'))?.split('=')[1] ||
               '';
    }

    /**
     * Show alert messages
     */
    function showSuccess(message) {
        const alert = document.createElement('div');
        alert.className = 'alert alert-success alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3';
        alert.style.zIndex = '9999';
        alert.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        document.body.appendChild(alert);
        setTimeout(() => alert.remove(), 5000);
    }

    function showError(message) {
        const alert = document.createElement('div');
        alert.className = 'alert alert-danger alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3';
        alert.style.zIndex = '9999';
        alert.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        document.body.appendChild(alert);
        setTimeout(() => alert.remove(), 5000);
    }
</script>
</body>
</html>
