<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verifikasi Email - Barterin</title>

    <link rel="stylesheet" href="/webix/webix.min.css">
    <link rel="stylesheet" href="/webix/skins/material.css">
    <script src="/webix/webix.min.js"></script>

    <style>
        body {
            margin: 0;
            padding: 0;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .verify-container {
            background: white;
            padding: 50px;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            max-width: 500px;
            width: 100%;
            text-align: center;
            animation: slideIn 0.5s ease-out;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .icon {
            font-size: 80px;
            margin-bottom: 20px;
        }

        .icon.success {
            color: #10b981;
        }

        .icon.error {
            color: #ef4444;
        }

        h1 {
            font-size: 28px;
            margin: 0 0 20px 0;
            color: #1f2937;
        }

        .message {
            font-size: 16px;
            color: #6b7280;
            margin-bottom: 30px;
            line-height: 1.6;
        }

        .btn {
            display: inline-block;
            padding: 14px 32px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 16px;
            transition: transform 0.2s, box-shadow 0.2s;
            border: none;
            cursor: pointer;
            margin: 5px;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }

        .btn-secondary {
            background: #6b7280;
        }

        .btn-secondary:hover {
            background: #4b5563;
            box-shadow: 0 10px 25px rgba(107, 114, 128, 0.4);
        }

        .divider {
            margin: 30px 0;
            height: 1px;
            background: #e5e7eb;
        }

        .info-box {
            background: #f3f4f6;
            padding: 20px;
            border-radius: 12px;
            margin-top: 20px;
            text-align: left;
        }

        .info-box h3 {
            margin: 0 0 10px 0;
            font-size: 16px;
            color: #1f2937;
        }

        .info-box ul {
            margin: 0;
            padding-left: 20px;
            color: #6b7280;
            font-size: 14px;
        }

        .info-box li {
            margin: 8px 0;
        }
    </style>
</head>
<body>
    <div class="verify-container">
        <% if (success) { %>
            <!-- Success State -->
            <div class="icon success">✅</div>
            <h1>Email Berhasil Diverifikasi!</h1>
            <p class="message">
                <%= message || 'Selamat! Email Anda telah berhasil diverifikasi. Sekarang Anda dapat menggunakan semua fitur Barterin.' %>
            </p>

            <div class="info-box">
                <h3>Anda sekarang dapat:</h3>
                <ul>
                    <li>Menambahkan barang atau jasa untuk di-barter</li>
                    <li>Mencari dan menawarkan barter kepada pengguna lain</li>
                    <li>Berkomunikasi melalui sistem pesan</li>
                    <li>Memberikan review setelah transaksi</li>
                </ul>
            </div>

            <div class="divider"></div>

            <a href="/auth" class="btn">Login Sekarang</a>

        <% } else { %>
            <!-- Error State -->
            <div class="icon error">❌</div>
            <h1>Verifikasi Gagal</h1>
            <p class="message">
                <%= message || 'Link verifikasi tidak valid atau sudah kadaluarsa.' %>
            </p>

            <div class="info-box">
                <h3>Kemungkinan penyebab:</h3>
                <ul>
                    <li>Link verifikasi sudah kadaluarsa (lebih dari 24 jam)</li>
                    <li>Link sudah pernah digunakan sebelumnya</li>
                    <li>Link tidak valid atau rusak</li>
                </ul>
            </div>

            <div class="divider"></div>

            <p style="font-size: 14px; color: #6b7280; margin-bottom: 20px;">
                Silakan minta link verifikasi baru atau hubungi admin jika masalah berlanjut.
            </p>

            <a href="/auth/register" class="btn btn-secondary">Kembali ke Register</a>
            <a href="/auth" class="btn">Login</a>
        <% } %>
    </div>

    <% if (success) { %>
    <script>
        // Auto redirect to login after 5 seconds
        setTimeout(function() {
            window.location.href = '/auth';
        }, 5000);

        // Show countdown
        let seconds = 5;
        const countdown = setInterval(function() {
            seconds--;
            if (seconds <= 0) {
                clearInterval(countdown);
            }
        }, 1000);
    </script>
    <% } %>
</body>
</html>
