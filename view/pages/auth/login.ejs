<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Platform Barter</title>
    
    <!-- Webix CSS dari folder public (LOKAL) -->
    <!-- ✅ BENAR - Akan load dari public folder -->
    <link rel="stylesheet" href="/webix/webix.min.css">
    <link rel="stylesheet" href="/webix/skins/material.css">

    <script src="/webix/webix.min.js"></script>
    
    <style>
        body {
            margin: 0;
            padding: 0;
            background: #f3f4f6;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }
        
        .page-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }
        
        .login-card {
            background: white;
            padding: 40px;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            max-width: 450px;
            width: 100%;
        }
        
        .brand {
            text-align: center;
            margin-bottom: 30px;
        }
        
        .brand-title {
            font-size: 36px;
            font-weight: bold;
            color: #667eea;
            margin: 0;
        }
        
        .brand-subtitle {
            color: #666;
            margin: 10px 0 0 0;
            font-size: 16px;
        }
        
        .footer {
            text-align: center;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #eee;
        }
        
        .footer a {
            color: #667eea;
            text-decoration: none;
            font-size: 14px;
            margin: 0 10px;
        }
        
        .footer a:hover {
            text-decoration: underline;
        }

        /* Tombol Login */
        .login-btn {
            width: 100%;
            padding: 12px 24px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 20px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
            box-sizing: border-box;
        }

        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(102, 126, 234, 0.6);
        }

        .login-btn:active {
            transform: translateY(0);
        }

        /* Tombol Registrasi */
        .register-btn {
            width: 100%;
            padding: 12px 24px;
            background: white;
            color: #667eea;
            border: 2px solid #667eea;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 12px;
            transition: all 0.3s ease;
            text-decoration: none;
            display: block;
            text-align: center;
            box-sizing: border-box;
        }

        .register-btn:hover {
            background: #f0f4ff;
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.2);
        }

        .register-btn:active {
            transform: translateY(1px);
        }

        /* Atau divider text */
        .divider-text {
            text-align: center;
            color: #999;
            margin: 20px 0 15px 0;
            font-size: 14px;
        }

        /* Links yang lebih rapi */
        .auth-links {
            text-align: center;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #eee;
        }

        .auth-links a {
            color: #667eea;
            text-decoration: none;
            font-size: 14px;
            margin: 0 8px;
            transition: all 0.3s ease;
        }

        .auth-links a:hover {
            text-decoration: underline;
            color: #764ba2;
        }

        .auth-links span {
            color: #ddd;
            margin: 0 5px;
        }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <div class="login-card">
            <div class="brand">
                <h1 class="brand-title">🔄 Barter</h1>
                <p class="brand-subtitle">Masuk ke Platform Barter</p>
            </div>

            <!-- Webix Form Container -->
            <div id="login-form"></div>

            <!-- Tombol Login dan Register -->
            <button class="login-btn" id="login-btn" onclick="handleLogin(event)">Login</button>
            <a href="/auth/register" class="register-btn">Buat Akun Baru</a>

            <!-- Divider -->
            <div class="divider-text">Atau</div>

            <!-- Links tambahan -->
            <div class="auth-links">
                <a href="/auth/forgot-password">Lupa Password?</a>
            </div>
        </div>
    </div>
    
    <!-- Webix JavaScript dari folder public (LOKAL) -->
    
    <script>
        let loginForm; // Reference to form

        // Function to sanitize input
        function sanitizeInput(input) {
            if (typeof input !== 'string') return input;
            return input
                .replace(/'/g, '')
                .replace(/"/g, '')
                .replace(/;/g, '')
                .replace(/--/g, '')
                .replace(/\/\*/g, '')
                .replace(/\*\//g, '')
                .replace(/xp_/g, '')
                .replace(/sp_/g, '')
                .trim();
        }

        // Handle login
        async function handleLogin(event) {
            event.preventDefault();

            if (!loginForm) {
                webix.message({ type: "error", text: "Form tidak ditemukan!" });
                return;
            }

            // Validasi form
            if (!loginForm.validate()) {
                webix.message({ type: "error", text: "Mohon isi email dan password!" });
                return;
            }

            const values = loginForm.getValues();
            const loginBtn = document.getElementById('login-btn');

            // Disable tombol selama proses
            loginBtn.disabled = true;
            loginBtn.textContent = 'Sedang login...';

            try {
                const response = await fetch('/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        email: values.email.trim(),
                        password: values.password
                    })
                });

                const result = await response.json();

                if (result.success) {
                    webix.message({
                        type: "success",
                        text: "Login berhasil! Mengalihkan..."
                    });
                    setTimeout(() => {
                        window.location.href = '/dashboard';
                    }, 1000);
                } else {
                    webix.message({
                        type: "error",
                        text: result.message || "Email atau password salah!"
                    });
                    loginBtn.disabled = false;
                    loginBtn.textContent = 'Login';
                }
            } catch (error) {
                console.error('Error:', error);
                webix.message({
                    type: "error",
                    text: "Gagal menghubungi server. Coba lagi!"
                });
                loginBtn.disabled = false;
                loginBtn.textContent = 'Login';
            }
        }

        webix.ready(function() {
            // Buat form login
            loginForm = webix.ui({
                view: "form",
                container: "login-form",
                borderless: true,
                elements: [
                    {
                        view: "text",
                        label: "Email",
                        name: "email",
                        labelPosition: "top",
                        placeholder: "contoh@email.com",
                        required: true,
                        invalidMessage: "Email tidak valid"
                    },
                    {
                        view: "text",
                        type: "password",
                        label: "Password",
                        name: "password",
                        labelPosition: "top",
                        placeholder: "Masukkan password",
                        required: true,
                        invalidMessage: "Password harus diisi"
                    }
                ]
            });
        });

        // Enter key untuk submit
        document.addEventListener('keypress', function(e) {
            if (e.key === 'Enter' && e.target.tagName === 'INPUT') {
                handleLogin(e);
            }
        });
    </script>
</body>
</html>
