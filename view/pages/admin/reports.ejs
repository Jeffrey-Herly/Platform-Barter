<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Laporan</title>

    <link rel="stylesheet" type="text/css" href="/webix/webix.min.css">
    <link rel="stylesheet" type="text/css" href="/webix/skins/webix.flat.css">
    <link rel="stylesheet" type="text/css" href="/css/navbar.css">
    <link rel="stylesheet" type="text/css" href="/css/mobile-responsive-fix.css">

    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: #f3f4f6;
            min-height: 100vh;
            color: #111827;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #ffffff;
            padding: 16px 20px;
            border-radius: 10px;
            border: 1px solid #e5e7eb;
            margin-bottom: 16px;
        }

        .page-title {
            font-size: 18px;
            font-weight: 600;
        }

        .back-button {
            padding: 8px 14px;
            border-radius: 999px;
            border: 1px solid #d1d5db;
            background: #ffffff;
            font-size: 13px;
            color: #374151;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-right: 12px;
        }

        .back-button:hover {
            background: #f3f4f6;
        }

        .filter-form {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .filter-select {
            padding: 6px 10px;
            border-radius: 8px;
            border: 1px solid #d1d5db;
            font-size: 13px;
        }

        .filter-button {
            padding: 6px 12px;
            border-radius: 8px;
            border: none;
            background: #4f46e5;
            color: white;
            font-size: 13px;
            cursor: pointer;
        }

        .filter-button:hover {
            background: #4338ca;
        }

        .card {
            background: #ffffff;
            border-radius: 10px;
            border: 1px solid #e5e7eb;
            padding: 16px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th, td {
            padding: 8px 6px;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
        }

        th {
            font-weight: 600;
            color: #6b7280;
            font-size: 12px;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 2px 8px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-gray {
            background: #e5e7eb;
            color: #374151;
        }

        .badge-yellow {
            background: #fef9c3;
            color: #854d0e;
        }

        .badge-green {
            background: #dcfce7;
            color: #15803d;
        }

        .badge-red {
            background: #fee2e2;
            color: #b91c1c;
        }

        .action-button {
            padding: 4px 8px;
            border-radius: 999px;
            border: 1px solid #d1d5db;
            background: #ffffff;
            font-size: 12px;
            cursor: pointer;
            margin-right: 4px;
        }

        .action-button:hover {
            background: #f3f4f6;
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <%- include('../../partials/navbar.ejs', { currentPage: 'admin', isAdminUser: true }) %>

        <div class="main-content">
            <div class="page-header">
                <div style="display:flex;align-items:center;gap:12px;">
                    <a href="/admin" class="back-button">
                        ← Kembali
                    </a>
                    <div class="page-title">Manajemen Laporan</div>
                </div>
                <form class="filter-form" method="GET" action="/admin/reports">
                    <select name="status" class="filter-select">
                        <option value="">Semua status</option>
                        <option value="PENDING" <%= statusFilter === 'PENDING' ? 'selected' : '' %>>Pending</option>
                        <option value="REVIEWING" <%= statusFilter === 'REVIEWING' ? 'selected' : '' %>>Reviewing</option>
                        <option value="RESOLVED" <%= statusFilter === 'RESOLVED' ? 'selected' : '' %>>Resolved</option>
                        <option value="DISMISSED" <%= statusFilter === 'DISMISSED' ? 'selected' : '' %>>Dismissed</option>
                    </select>
                    <button type="submit" class="filter-button">Filter</button>
                </form>
            </div>

            <% if (error) { %>
                <div style="background:#fee2e2;color:#b91c1c;padding:10px 12px;border-radius:8px;border:1px solid #fecaca;margin-bottom:16px;font-size:13px;">
                    <%= error %>
                </div>
            <% } %>

            <div class="card">
                <table>
                    <thead>
                        <tr>
                            <th>Jenis</th>
                            <th>Status</th>
                            <th>Pelapor</th>
                            <th>Target</th>
                            <th>Dibuat</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (reports && reports.length > 0) { %>
                            <% reports.forEach(function(r) { %>
                                <tr data-report-id="<%= r.report_id %>">
                                    <td><%= r.report_type %></td>
                                    <td>
                                        <% if (r.status === 'PENDING') { %>
                                            <span class="badge badge-yellow">PENDING</span>
                                        <% } else if (r.status === 'REVIEWING') { %>
                                            <span class="badge badge-gray">REVIEWING</span>
                                        <% } else if (r.status === 'RESOLVED') { %>
                                            <span class="badge badge-green">RESOLVED</span>
                                        <% } else { %>
                                            <span class="badge badge-red">DISMISSED</span>
                                        <% } %>
                                    </td>
                                    <td><%= r.reporter_name %> (<%= r.reporter_email %>)</td>
                                    <td>
                                        <% if (r.target_user_name) { %>
                                            <%= r.target_user_name %> (<%= r.target_user_email %>)
                                        <% } else if (r.target_item_title) { %>
                                            Item: <%= r.target_item_title %>
                                        <% } else { %>
                                            -
                                        <% } %>
                                    </td>
                                    <td><%= new Date(r.created_at).toLocaleString('id-ID') %></td>
                                    <td>
                                        <button class="action-button js-set-status" data-status="REVIEWING">Review</button>
                                        <button class="action-button js-set-status" data-status="RESOLVED">Resolve</button>
                                        <button class="action-button js-set-status" data-status="DISMISSED">Dismiss</button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="6">Tidak ada laporan.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="/webix/webix.min.js"></script>
    <script src="/js/navbar.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.js-set-status').forEach(function(btn) {
                btn.addEventListener('click', async function() {
                    const row = this.closest('tr');
                    const reportId = row.getAttribute('data-report-id');
                    const newStatus = this.getAttribute('data-status');

                    const confirmText = 'Ubah status laporan menjadi ' + newStatus + '?';
                    if (!confirm(confirmText)) return;

                    try {
                        const res = await fetch('/api/admin/reports/' + reportId + '/status', {
                            method: 'PATCH',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({ status: newStatus })
                        });

                        const data = await res.json();
                        if (!res.ok || !data.success) {
                            alert(data.message || 'Gagal mengubah status laporan');
                            return;
                        }

                        window.location.reload();
                    } catch (e) {
                        console.error(e);
                        alert('Terjadi kesalahan saat mengubah status laporan');
                    }
                });
            });
        });
    </script>
</body>
</html>
