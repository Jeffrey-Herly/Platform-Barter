# ============================================
# ENVIRONMENT VARIABLES
# Copy this file to .env and fill with your values
# ============================================

# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=Jeffrey@9010

# JWT Configuration
JWT_SECRET=change-this-to-random-secret-minimum-32-characters-for-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# Cookie Configuration
COOKIE_SECRET=change-this-cookie-secret-key-for-production

# CORS (Frontend URL)
FRONTEND_URL=http://localhost:3000

# Bcrypt Salt Rounds
BCRYPT_SALT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=15m

# Session
SESSION_SECRET=change-this-session-secret-for-production

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@barterplatform.com

# File Upload (Optional)
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=info